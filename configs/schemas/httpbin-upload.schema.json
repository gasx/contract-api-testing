{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HTTPBingo multipart upload response",
  "type": "object",
  "required": [
    "files",
    "form",
    "url"
  ],
  "properties": {
    "files": {
      "type": "object",
      "required": [
        "file"
      ],
      "properties": {
        "file": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "form": {
      "type": "object",
      "required": [
        "title"
      ],
      "properties": {
        "title": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "url": {
      "type": "string"
    }
  }
}
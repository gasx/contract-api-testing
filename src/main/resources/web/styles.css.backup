:root {
    --bg: #0f172a;
    --panel: #111827;
    --panel2: #1f2937;
    --text: #e5e7eb;
    --muted: #94a3b8;
    --green: #22c55e;
    --red: #ef4444;
    --yellow: #f59e0b;
    --blue: #38bdf8;
    --border: #263244;
}

* {
    box-sizing: border-box;
}

body {
    margin: 0;
    padding: 20px;
    font-family: Arial, sans-serif;
    background: radial-gradient(circle at top, #1e293b 0, #0f172a 45%);
    color: var(--text);
}

.header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 16px;
}

.title {
    font-size: 26px;
    font-weight: 800;
}

.subtitle {
    margin-top: 5px;
    color: var(--muted);
    font-size: 13px;
}

.status-pill {
    padding: 8px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 800;
    letter-spacing: 0.4px;
    white-space: nowrap;
}

.status-pass {
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.45);
    color: var(--green);
}

.status-fail {
    background: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.45);
    color: var(--red);
}

.cards {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    margin-bottom: 14px;
}

.card {
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: rgba(17, 24, 39, 0.92);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
}

.card-label {
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.7px;
    text-transform: uppercase;
}

.card-value {
    margin-top: 6px;
    font-size: 26px;
    font-weight: 900;
}

.green {
    color: var(--green);
}

.red {
    color: var(--red);
}

.yellow {
    color: var(--yellow);
}

.blue {
    color: var(--blue);
}

.grid {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: 12px;
    margin-bottom: 14px;
}

.panel {
    padding: 14px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: rgba(17, 24, 39, 0.92);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
}

.panel h2 {
    margin: 0 0 10px;
    font-size: 16px;
}

.health {
    margin-top: 12px;
}

.bar {
    height: 12px;
    overflow: hidden;
    border-radius: 999px;
    background: #334155;
}

.bar-fill {
    width: 0;
    height: 100%;
    background: linear-gradient(90deg, var(--green), var(--blue));
}

.filters {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 10px;
}

button {
    padding: 7px 10px;
    border: 1px solid var(--border);
    border-radius: 9px;
    background: var(--panel2);
    color: var(--text);
    cursor: pointer;
    font-size: 12px;
}

button.active {
    border-color: var(--blue);
    color: var(--blue);
}

input {
    width: 100%;
    margin-bottom: 10px;
    padding: 9px 10px;
    border: 1px solid var(--border);
    border-radius: 10px;
    outline: none;
    background: #0b1220;
    color: var(--text);
    font-size: 13px;
}

.table-wrap {
    overflow-x: auto;
}

table {
    width: 100%;
    border-collapse: collapse;
}

th,
td {
    padding: 8px 10px;
    border-bottom: 1px solid var(--border);
    text-align: left;
    vertical-align: top;
    font-size: 13px;
}

th {
    color: var(--muted);
    font-size: 11px;
    text-transform: uppercase;
}

tbody tr {
    cursor: pointer;
}

tbody tr:hover {
    background: rgba(56, 189, 248, 0.04);
}

.badge {
    display: inline-block;
    padding: 4px 7px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 800;
}

.badge-pass {
    background: rgba(34, 197, 94, 0.16);
    color: var(--green);
}

.badge-fail {
    background: rgba(239, 68, 68, 0.16);
    color: var(--red);
}

.method {
    color: var(--blue);
    font-weight: 800;
}

.error {
    margin-bottom: 4px;
    color: #fecaca;
}

.small {
    color: var(--muted);
    font-size: 11px;
}

.file-transfer {
    min-width: 180px;
    margin-bottom: 6px;
    padding: 7px 8px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #0b1220;
}

.file-kind {
    display: inline-block;
    margin-bottom: 4px;
    color: var(--blue);
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
}

.file-link {
    display: inline-block;
    margin-top: 6px;
    color: var(--blue);
    font-size: 11px;
    font-weight: 700;
    text-decoration: none;
}

.file-link:hover {
    text-decoration: underline;
}

.file-preview {
    display: block;
    max-width: 150px;
    max-height: 90px;
    margin-top: 6px;
    border: 1px solid var(--border);
    border-radius: 6px;
}

@media (max-width: 1000px) {
    body {
        padding: 12px;
    }

    .header {
        align-items: flex-start;
        flex-direction: column;
    }

    .cards {
        grid-template-columns: repeat(2, 1fr);
    }

    .grid {
        grid-template-columns: 1fr;
    }
}

.integration-run {
    min-width: 150px;
    margin-bottom: 6px;
    padding: 7px 8px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: #0b1220;
}

.integration-name {
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
}

.integration-type {
    display: inline-block;
    margin-left: 4px;
    padding: 2px 6px;
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.12);
    color: var(--blue);
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
}

.integration-status-ok {
    color: var(--green);
    font-weight: 800;
}

.integration-status-bad {
    color: var(--red);
    font-weight: 800;
}

.integration-error {
    margin-top: 4px;
    color: #fecaca;
    font-size: 11px;
    line-height: 1.3;
}

.integration-run {
    min-width: 180px;
    margin-bottom: 8px;
    padding: 8px 9px;
    border: 1px solid var(--border);
    border-radius: 9px;
    background: #0b1220;
}

.integration-run-error {
    border-color: rgba(239, 68, 68, 0.55);
    background: rgba(127, 29, 29, 0.18);
}

.integration-head {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 5px;
    margin-bottom: 3px;
}

.integration-name {
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
}

.integration-type {
    display: inline-block;
    padding: 2px 6px;
    border-radius: 999px;
    background: rgba(56, 189, 248, 0.12);
    color: var(--blue);
    font-size: 10px;
    font-weight: 800;
    text-transform: uppercase;
}

.integration-retry {
    display: inline-block;
    padding: 2px 6px;
    border-radius: 999px;
    background: rgba(250, 204, 21, 0.12);
    color: #fde68a;
    font-size: 10px;
    font-weight: 800;
}

.integration-status-ok {
    color: var(--green);
    font-weight: 800;
}

.integration-status-bad {
    color: var(--red);
    font-weight: 800;
}

.integration-error {
    margin-top: 5px;
    color: #fecaca;
    font-size: 11px;
    line-height: 1.35;
}

.integration-vars {
    margin-top: 6px;
    font-size: 11px;
}

.integration-vars summary {
    cursor: pointer;
    color: #93c5fd;
    font-weight: 700;
}

.integration-var-row {
    display: grid;
    grid-template-columns: 74px 1fr;
    gap: 6px;
    margin-top: 4px;
    padding-top: 4px;
    border-top: 1px solid rgba(148, 163, 184, 0.14);
}

.integration-var-key {
    color: #94a3b8;
    overflow: hidden;
    text-overflow: ellipsis;
}

.integration-var-value {
    color: #e5e7eb;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.integration-var-more {
    margin-top: 4px;
    color: #94a3b8;
}
.operation-response-block {
    min-width: 180px;
    margin-top: 8px;
    padding: 8px 9px;
    border: 1px solid var(--border);
    border-radius: 9px;
    background: #0b1220;
}

.operation-response-block[open] {
    border-color: rgba(56, 189, 248, 0.45);
}

.operation-response-block summary {
    cursor: pointer;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
    list-style: none;
}

.operation-response-block summary::-webkit-details-marker {
    display: none;
}

.operation-response-block summary::before {
    content: "▶";
    display: inline-block;
    margin-right: 6px;
    color: var(--muted);
    font-size: 10px;
    transition: transform 0.15s ease;
}

.operation-response-block[open] summary::before {
    transform: rotate(90deg);
}

.operation-response-meta {
    margin-top: 8px;
    margin-bottom: 8px;
    padding-top: 6px;
    border-top: 1px solid rgba(148, 163, 184, 0.14);
    color: var(--muted);
    font-size: 11px;
    line-height: 1.35;
    word-break: break-word;
}

.operation-response-body {
    width: 100%;
    max-width: 520px;
    max-height: 320px;
    margin: 0;
    padding: 10px;
    overflow: auto;
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 8px;
    background: #020617;
    color: var(--text);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 11px;
    line-height: 1.45;
    white-space: pre-wrap;
    word-break: break-word;
}

.operation-response-body::-webkit-scrollbar {
    width: 8px;
    height: 8px;
}

.operation-response-body::-webkit-scrollbar-track {
    background: #0b1220;
}

.operation-response-body::-webkit-scrollbar-thumb {
    border-radius: 999px;
    background: #334155;
}

.operation-response-body::-webkit-scrollbar-thumb:hover {
    background: #475569;
}

.results-head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 10px;
}

.test-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
}

.test-card-row {
    padding: 14px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background: rgba(15, 23, 42, 0.74);
}

.test-card-pass {
    border-left: 4px solid var(--green);
}

.test-card-fail {
    border-left: 4px solid var(--red);
}

.test-card-header {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: flex-start;
}

.test-title-block {
    min-width: 0;
}

.test-title-line {
    display: flex;
    align-items: center;
    gap: 10px;
}

.test-title-line h3 {
    margin: 0;
    font-size: 17px;
    line-height: 1.25;
}

.test-id {
    margin-top: 5px;
    color: var(--muted);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 11px;
}

.test-description {
    margin-top: 10px;
    color: var(--text);
    font-size: 13px;
    line-height: 1.45;
}

.test-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 5px;
    margin-top: 8px;
}

.test-tag {
    padding: 3px 7px;
    border: 1px solid rgba(56, 189, 248, 0.28);
    border-radius: 999px;
    color: var(--blue);
    background: rgba(56, 189, 248, 0.08);
    font-size: 11px;
    font-weight: 700;
}

.test-metrics {
    display: flex;
    gap: 8px;
    flex-shrink: 0;
}

.metric-box,
.http-summary {
    min-width: 92px;
    padding: 8px 10px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: #0b1220;
}

.metric-label {
    color: var(--muted);
    font-size: 10px;
    text-transform: uppercase;
}

.metric-value {
    margin-top: 4px;
    font-size: 14px;
    font-weight: 900;
}

.http-ok .metric-value {
    color: var(--green);
}

.http-bad .metric-value {
    color: var(--red);
}

.test-main-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(260px, 0.8fr);
    gap: 10px;
    margin-top: 12px;
}

.test-section-card {
    padding: 10px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: #0b1220;
}

.section-title {
    margin-bottom: 8px;
    color: var(--muted);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.6px;
    text-transform: uppercase;
}

.request-line {
    margin-bottom: 10px;
    padding: 8px;
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 8px;
    background: #020617;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 12px;
    word-break: break-word;
}

.request-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
}

.request-part {
    min-width: 0;
}

.request-part-title {
    margin-bottom: 5px;
    color: var(--blue);
    font-size: 11px;
    font-weight: 800;
}

.kv-row {
    display: grid;
    grid-template-columns: 120px minmax(0, 1fr);
    gap: 8px;
    padding: 5px 0;
    border-bottom: 1px solid rgba(148, 163, 184, 0.1);
    font-size: 12px;
}

.kv-key {
    color: var(--muted);
    word-break: break-word;
}

.kv-value {
    color: var(--text);
    word-break: break-word;
}

.json-preview {
    max-height: 180px;
    margin: 0;
    padding: 8px;
    overflow: auto;
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 8px;
    background: #020617;
    color: var(--text);
    font-size: 11px;
    line-height: 1.45;
    white-space: pre-wrap;
    word-break: break-word;
}

.result-facts {
    display: grid;
    gap: 8px;
    font-size: 12px;
    word-break: break-word;
}

.test-details-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 10px;
    margin-top: 10px;
}

.test-detail {
    padding: 9px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: rgba(2, 6, 23, 0.44);
}

.test-detail summary {
    cursor: pointer;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
}

.test-detail > *:not(summary) {
    margin-top: 8px;
}

.ok-note {
    padding: 8px;
    border: 1px solid rgba(34, 197, 94, 0.25);
    border-radius: 8px;
    background: rgba(34, 197, 94, 0.08);
    color: var(--green);
    font-size: 12px;
}

.error-card {
    padding: 8px;
    border: 1px solid rgba(239, 68, 68, 0.25);
    border-radius: 8px;
    background: rgba(239, 68, 68, 0.08);
}

.empty-state {
    padding: 18px;
    border: 1px dashed var(--border);
    border-radius: 12px;
    color: var(--muted);
    text-align: center;
}

.operation-response-block {
    min-width: 180px;
    margin-top: 8px;
    padding: 8px 9px;
    border: 1px solid var(--border);
    border-radius: 9px;
    background: #0b1220;
}

.operation-response-block[open] {
    border-color: rgba(56, 189, 248, 0.45);
}

.operation-response-block summary {
    cursor: pointer;
    color: var(--blue);
    font-size: 12px;
    font-weight: 800;
}

.operation-response-meta {
    margin-top: 8px;
    margin-bottom: 8px;
    padding-top: 6px;
    border-top: 1px solid rgba(148, 163, 184, 0.14);
    color: var(--muted);
    font-size: 11px;
    line-height: 1.35;
    word-break: break-word;
}

.operation-response-body {
    width: 100%;
    max-height: 320px;
    margin: 0;
    padding: 10px;
    overflow: auto;
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 8px;
    background: #020617;
    color: var(--text);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 11px;
    line-height: 1.45;
    white-space: pre-wrap;
    word-break: break-word;
}

@media (max-width: 1100px) {
    .test-card-header,
    .test-main-grid,
    .test-details-grid,
    .request-grid {
        display: block;
    }

    .test-metrics {
        margin-top: 10px;
    }

    .test-section-card,
    .test-detail {
        margin-top: 10px;
    }
}

.header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
}

.top-link {
    display: inline-block;
    padding: 7px 10px;
    border: 1px solid var(--border);
    border-radius: 9px;
    background: var(--panel2);
    color: var(--blue);
    text-decoration: none;
    cursor: pointer;
    font-size: 12px;
    font-weight: 800;
}

.top-link:hover {
    border-color: var(--blue);
}

.builder-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(420px, 0.9fr);
    gap: 14px;
    align-items: start;
}

.builder-form {
    display: grid;
    gap: 14px;
}

.builder-preview {
    min-width: 0;
}

.sticky-panel {
    position: sticky;
    top: 16px;
}

.field-label {
    display: block;
    margin: 10px 0 5px;
    color: var(--muted);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.5px;
    text-transform: uppercase;
}

textarea,
select {
    width: 100%;
    margin-bottom: 10px;
    padding: 9px 10px;
    border: 1px solid var(--border);
    border-radius: 10px;
    outline: none;
    background: #0b1220;
    color: var(--text);
    font-size: 13px;
}

textarea {
    min-height: 90px;
    resize: vertical;
    font-family: Arial, sans-serif;
}

select {
    appearance: none;
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
}

.section-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
}

.section-head h2 {
    margin: 0;
}

.dynamic-list {
    display: grid;
    gap: 8px;
    margin-top: 10px;
}

.builder-row {
    display: grid;
    grid-template-columns: minmax(120px, 0.7fr) minmax(160px, 1fr) auto;
    gap: 8px;
    align-items: center;
}

.builder-assert-row {
    grid-template-columns: minmax(160px, 1fr) 130px minmax(150px, 0.8fr) auto;
}

.builder-row input,
.builder-row select {
    margin: 0;
}

.json-input {
    min-height: 160px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
}

.builder-json-preview {
    min-height: 680px;
    max-height: calc(100vh - 160px);
    margin: 10px 0 0;
    padding: 14px;
    overflow: auto;
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 12px;
    background: #020617;
    color: var(--text);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 12px;
    line-height: 1.5;
    white-space: pre;
}

.integration-builder-card {
    padding: 10px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: #0b1220;
}

.remove-wide {
    width: 100%;
    margin-top: 8px;
    color: var(--red);
}

@media (max-width: 1100px) {
    .builder-layout,
    .form-row,
    .builder-row,
    .builder-assert-row {
        display: block;
    }

    .builder-row > *,
    .builder-assert-row > * {
        margin-top: 8px;
    }

    .sticky-panel {
        position: static;
    }

    .builder-json-preview {
        min-height: 360px;
        max-height: 520px;
    }
}

.tests-list {
    display: grid;
    gap: 8px;
    margin-top: 10px;
}

.test-list-item {
    display: block;
    width: 100%;
    padding: 9px 10px;
    text-align: left;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: #0b1220;
}

.test-list-item-active {
    border-color: var(--blue);
    background: rgba(56, 189, 248, 0.08);
}

.test-list-title {
    display: block;
    color: var(--text);
    font-size: 13px;
    font-weight: 800;
}

.test-list-meta {
    display: block;
    margin-top: 4px;
    color: var(--muted);
    font-size: 11px;
}
